{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Data source=localhost;Database=ToDoFlow;Trusted_Connection=true;Encrypt=True;TrustServerCertificate=true"
  },

  "JwtSettings": {
    "Issuer": "ToDoFlow",
    "Audience": "ToDoFlowUsers",
    "ExpirationMinutesJwt": 5,
    "ExpirationMinutesResetPassword": 15,
    "ExpirationDaysRefresh": 7,
    "SecretKey": "YOUR_SECRET_KEY_HERE"
  },

  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpFrom": "SEU_EMAIL_@gmail.com",
    "SmtpName": "ToDoFlow",
    "SmtpPassword": "YOUR_EMAIL_PASSWORD_HERE"
  },

  "FrontEnd": {
    "Url": "http://localhost:4200"
  },

  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  }
}